DEBUG=True
SECRET_KEY=replace-with-random-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost

# Shared MySQL database (same as iuoss_dashboard)
DB_NAME=iuoss_student_data
DB_USER=iuoss_app
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

TIME_ZONE=Asia/Ho_Chi_Minh

# LDAP — trường HCMIU
LDAP_SERVER_URI=ldap://ldap.hcmiu.edu.vn:389
LDAP_BIND_DN=cn=ctsv,dc=hcmiu,dc=edu,dc=vn
LDAP_BIND_PASSWORD=replace-with-ldap-service-account-password
LDAP_SEARCH_BASE=dc=hcmiu,dc=edu,dc=vn
LDAP_USER_ATTR=uid
