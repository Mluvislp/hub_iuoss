# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  IUOSS Hub — Backend environment                                           ║
# ║  Copy file này thành `.env` rồi điền giá trị. KHÔNG commit `.env`.         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Môi trường ────────────────────────────────────────────────────────────────
# local | staging | production. Là nguồn sự thật duy nhất cho cấu hình môi trường.
# DEBUG tự suy ra: local → True, còn lại → False (có thể override bằng DEBUG=...).
DJANGO_ENV=local

# Bắt buộc đổi trong production. Sinh chuỗi mới:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-random-secret-key

# Override DEBUG nếu cần (thường để trống, để DJANGO_ENV quyết định)
# DEBUG=False

# Host được phép phục vụ. Production thêm domain + IP LAN.
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Frontend origins (CORS + CSRF) ───────────────────────────────────────────
# Origin browser của frontend. Dev: localhost:3000. Production: domain thật.
#   local:      http://localhost:3000,http://127.0.0.1:3000
#   production: https://hub.iuoss.com
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Mặc định CSRF_TRUSTED_ORIGINS = FRONTEND_ORIGINS. Chỉ set khi cần khác:
# CSRF_TRUSTED_ORIGINS=https://hub.iuoss.com

# ── Database (MySQL — DÙNG CHUNG với dashboard_iuoss) ────────────────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=iuoss_student_data
DB_USER=iuoss_app
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

TIME_ZONE=Asia/Ho_Chi_Minh

# ── LDAP — trường HCMIU ──────────────────────────────────────────────────────
LDAP_SERVER_URI=ldap://ldap.hcmiu.edu.vn:389
LDAP_BIND_DN=cn=ctsv,dc=hcmiu,dc=edu,dc=vn
LDAP_BIND_PASSWORD=replace-with-ldap-service-account-password
LDAP_SEARCH_BASE=dc=hcmiu,dc=edu,dc=vn
LDAP_USER_ATTR=uid

# ── Security (chỉ áp dụng khi DEBUG=False) ───────────────────────────────────
# HSTS: bật khi chắc chắn toàn site HTTPS. 31536000 = 1 năm.
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# Redirect HTTP→HTTPS ở tầng Django (thường để Cloudflare/Nginx lo → để False).
# SECURE_SSL_REDIRECT=False
