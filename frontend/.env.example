# ── API URL ───────────────────────────────────────────────────────────────────
#
# NEXT_PUBLIC_API_URL kiểm soát browser gọi API tới đâu.
#
# Dev (.env.local):
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
#   → Browser gọi thẳng Django dev server (CORS đã cấu hình cho localhost:3000)
#   → Không cần proxy qua Next.js
#
# Production (KHÔNG set biến này):
#   API_BASE = '/api'  (relative URL)
#   → Browser gọi https://hub.iuoss.com/api/...
#   → Nginx định tuyến /api/ → Gunicorn :8002 (cùng domain, không cần CORS)
#
# KHÔNG bao giờ set NEXT_PUBLIC_API_URL=http://127.0.0.1:8002/api trên server production
# vì NEXT_PUBLIC_* được embed vào bundle lúc build — browser sẽ thấy IP nội bộ.
#
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
